# unimos las tablas importantes para realizar las mediciones de los resultados por equipo
import pandas as pd

# Combine
df_combine = pd.read_sql("""
SELECT
    player_id,
    season,
    wingspan,
    max_vertical_leap,
    lane_agility_time,
    three_quarter_sprint,
    bench_press
FROM draft_combine_stats
""", conn)

# Info jugador
df_players = pd.read_sql("""
SELECT
    person_id,
    display_first_last,
    team_id,
    from_year,
    height,
    weight,
    position
FROM common_player_info
WHERE team_id IS NOT NULL
""", conn)

# Alinear nombres de ID
df_combine.rename(columns={"player_id": "person_id"}, inplace=True)

# Merge físico + equipo
df_physical = df_combine.merge(df_players, on="person_id", how="inner")

df_physical.head()

# limpieza basica de peso y altura
def height_to_cm(h):
    try:
        feet, inches = h.split("-")
        return (int(feet) * 30.48) + (int(inches) * 2.54)
    except:
        return None

df_physical["height_cm"] = df_physical["height"].apply(height_to_cm)
df_physical["weight_kg"] = pd.to_numeric(df_physical["weight"], errors="coerce") * 0.453592

# sacamos promedio fisico por equipo
df_team_physical = df_physical.groupby("team_id").agg({
    "wingspan": "mean",
    "max_vertical_leap": "mean",
    "lane_agility_time": "mean",
    "height_cm": "mean",
    "weight_kg": "mean"
}).reset_index()

df_team_physical.rename(columns={
    "wingspan": "avg_wingspan",
    "max_vertical_leap": "avg_vertical",
    "lane_agility_time": "avg_agility",
    "height_cm": "avg_height_cm",
    "weight_kg": "avg_weight_kg"
}, inplace=True)

df_team_physical.head()

# sacamos metricas de rendimiento por equipo
# primero normalizamos home/away

df_game = pd.read_sql("""
SELECT
    season_id,
    team_id_home,
    pts_home,
    blk_home,
    stl_home,
    plus_minus_home,
    team_id_away,
    pts_away,
    blk_away,
    stl_away,
    plus_minus_away
FROM game
WHERE season_type = 'Regular Season'
""", conn)

# Home
home = df_game[["season_id","team_id_home","pts_home","blk_home","stl_home","plus_minus_home"]]
home.columns = ["season","team_id","pts","blk","stl","plus_minus"]

# Away
away = df_game[["season_id","team_id_away","pts_away","blk_away","stl_away","plus_minus_away"]]
away.columns = ["season","team_id","pts","blk","stl","plus_minus"]

df_long = pd.concat([home, away])

# agrupamos
df_team_performance = df_long.groupby("team_id").agg({
    "pts": "mean",
    "blk": "mean",
    "stl": "mean",
    "plus_minus": "mean"
}).reset_index()

df_team_performance.rename(columns={
    "pts": "avg_pts",
    "blk": "avg_blk",
    "stl": "avg_stl",
    "plus_minus": "avg_plus_minus"
}, inplace=True)

df_team_performance.head()

# Normalizar team_id en ambos DF para que coincidan

df_team_physical["team_id"] = pd.to_numeric(df_team_physical["team_id"], errors="coerce")
df_team_performance["team_id"] = pd.to_numeric(df_team_performance["team_id"], errors="coerce")

# Eliminar nulos que salieron de conversiones fallidas
df_team_physical = df_team_physical.dropna(subset=["team_id"]).copy()
df_team_performance = df_team_performance.dropna(subset=["team_id"]).copy()

# Pasar a int64
df_team_physical["team_id"] = df_team_physical["team_id"].astype("int64")
df_team_performance["team_id"] = df_team_performance["team_id"].astype("int64")

print(df_team_physical["team_id"].dtype, df_team_performance["team_id"].dtype)
print("Teams físicos:", df_team_physical["team_id"].nunique())
print("Teams performance:", df_team_performance["team_id"].nunique())

df_analytic = df_team_physical.merge(df_team_performance, on="team_id", how="inner")
print("✅ Dataset final:", df_analytic.shape)
df_analytic.head()

# Nulos, tipo y resumenes
df_analytic.info()
df_analytic.isna().sum()
df_analytic.describe()

# Detectamos outliers
num_cols = [c for c in df_analytic.columns if c != "team_id"]
q1 = df_analytic[num_cols].quantile(0.25)
q3 = df_analytic[num_cols].quantile(0.75)
iqr = q3 - q1
outliers = ((df_analytic[num_cols] < (q1 - 1.5*iqr)) | (df_analytic[num_cols] > (q3 + 1.5*iqr))).sum()
outliers.sort_values(ascending=False)

