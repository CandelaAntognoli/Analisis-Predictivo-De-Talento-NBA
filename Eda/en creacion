# armamos un " perfil fisico promedio por equipo"
from scipy.stats import zscore

df_index = df_analytic.copy()

# Variables físicas (agility se invierte porque menor es mejor)
df_index["agility_inv"] = -df_index["avg_agility"]

phys_cols = ["avg_wingspan","avg_vertical","agility_inv","avg_height_cm","avg_weight_kg"]
for c in phys_cols:
    df_index[c+"_z"] = zscore(df_index[c])

df_index["physical_index"] = df_index[[c+"_z" for c in phys_cols]].mean(axis=1)

df_index.sort_values("physical_index", ascending=False).head(10)[
    ["team_id","physical_index","avg_plus_minus","avg_blk","avg_stl"]
]

plt.figure(figsize=(7,5))
sns.regplot(data=df_index, x="physical_index", y="avg_plus_minus")
plt.title("Physical Index vs Plus-Minus (equipo)")
plt.show()

