UNZIP_DIR = "/content/nba_unzipped"
os.makedirs(UNZIP_DIR, exist_ok=True)

DB_PATH = None

if best_path.lower().endswith(".zip"):
    with zipfile.ZipFile(best_path, "r") as z:
        members = z.namelist()
        sqlite_members = [m for m in members if m.lower().endswith(".sqlite")]
        if not sqlite_members:
            raise FileNotFoundError("❌ El zip no contiene ningún .sqlite.")
        target_member = sqlite_members[0]
        z.extract(target_member, UNZIP_DIR)
        DB_PATH = os.path.join(UNZIP_DIR, target_member)
else:
    # Es sqlite directo -> copiar a /content para estabilidad
    DB_PATH = "/content/nba.sqlite"
    os.system(f'cp "{best_path}" "{DB_PATH}"')

